# Normalize repository text files. Explicit exceptions below keep Windows
# command scripts compatible with native Windows tooling.
* text=auto eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf

# Source, configuration, descriptors, and documentation
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.inl text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.py text eol=lf
*.ps1 text eol=lf
*.uproject text eol=lf
*.uplugin text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.sha256 text eol=lf

# Unreal assets are binary and must never be line-ending normalized or merged
# as text. Git LFS can be added later when the repository storage policy is set.
*.uasset binary
*.umap binary
*.ubulk binary
*.uexp binary
*.uptnl binary

