# External local reference project. The reproducible identity and derived
# evidence are kept in .planning/evidence instead of committing Epic content.
/LyraStarterGame/

# Unreal Engine generated directories
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Unreal project files generated by IDE/project-file tools
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.VC.opendb
*.vsconfig
*.code-workspace
*.csproj.props

# IDE and editor-local state
.vs/
.idea/
.vscode/
*.user
*.userprefs

# Python caches and local environments
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# .NET/C# build output used by UE automation tooling
obj/

# Operating-system metadata
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Temporary and patch files
*.tmp
*.temp
*.bak
*.orig
*.rej
*~

# Project source, descriptors, research records, and audit evidence are not
# matched by these rules and remain trackable.
